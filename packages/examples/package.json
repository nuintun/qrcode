{
  "name": "rspack-antd-builder",
  "description": "A rspack-based antd build tool.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=16.0.0"
  },
  "author": {
    "name": "nuintun",
    "email": "nuintun@qq.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/nuintun/rspack-antd-builder",
  "scripts": {
    "lint": "tsc --noEmit",
    "start": "node server.ts",
    "prod": "node tools/rspack.config.prod.ts",
    "dev": "nodemon --exec node tools/rspack.config.dev.ts",
    "format": "prettier --write . --ignore-path .prettierignore"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@nuintun/qrcode": "workspace:*",
