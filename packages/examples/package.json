    "browser-fs-access": "^0.38.0",
    "chardet": "^2.1.1",
    "classnames": "^2.5.1",
    "copy-to-clipboard": "^4.0.2",
    "fast-equals": "^6.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.1"
  },
  "devDependencies": {
    "@nuintun/svgo-loader": "^0.6.1",
    "@rspack/core": "^2.0.3",
    "@rspack/plugin-react-refresh": "^2.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
